# ── Credentials (NEVER commit these) ──────────────────────────────────────
.env
.env.*
!.env.example
secrets.json
credentials.json

# ── Virtual Environment ────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Bot Runtime Artifacts (auto-generated — run `python bootstrap.py`) ──────
# Per-symbol OHLCV parquet files (~1 GB for all NSE stocks)
# Per-symbol fundamental JSON files
cache/
# Universe + fundamentals tracked in git so EC2 gets them via git pull
# (NSE blocks EC2 IPs — these are fetched on GitHub Actions runners instead)
# OHLCV parquet files (~1 GB) stay gitignored — too large for git
!cache/universe.json
!cache/fundamentals/
!cache/fundamentals/*.json
!configs/.env.*
!configs/*.sh

# Rotating bot.log files
logs/

# Paper trading ledgers (per-instance, not rsynced)
ledgers/
!ledgers/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── IDEs ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
grafana/provisioning/dashboards/*.json
grafana/.pushed
grafana/
