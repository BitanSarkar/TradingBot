# ── Credentials (NEVER commit these) ──────────────────────────────────────
.env
.env.*
!.env.example
secrets.json
credentials.json

# ── Virtual Environment ────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Bot Runtime Artifacts (auto-generated — run `python bootstrap.py`) ──────
# Per-symbol OHLCV parquet files (~1 GB for all NSE stocks)
# Per-symbol fundamental JSON files
cache/
# Universe cache is tracked in git so EC2 gets it via git pull (NSE blocks EC2 IPs)
!cache/universe.json
!configs/.env.*
!configs/*.sh

# Rotating bot.log files
logs/

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── IDEs ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
