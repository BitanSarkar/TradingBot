# =============================================================================
#  PROFILE: momentum
#  Philosophy: Score velocity + intraday pulse are the primary signals.
#              "Is the stock MOVING right now?" > fundamentals/regime.
#              High intraday weight — catches stocks having strong sessions.
#  Best for:  Trending markets with clear sector rotations.
# =============================================================================

GROWW_API_KEY=YOUR_API_KEY
GROWW_SECRET=YOUR_SECRET
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:729756086652:NotifySelft

BOT_DRY_RUN=true
BOT_POLL_INTERVAL=300
BOT_POLL_INTERVAL_OPEN=60
BOT_POLL_INTERVAL_CLOSED=3600

LOG_MAX_BYTES=1073741824
LOG_BACKUP_COUNT=19

RISK_MAX_DAILY_LOSS=2500.0
RISK_MAX_HOLDINGS=10
RISK_MAX_QTY_PER_ORDER=10
RISK_DYNAMIC_SIZING=true
RISK_DEPLOY_FRACTION=0.90
RISK_DRY_RUN_BALANCE=1000000.0

EXIT_ATR_PERIOD=14
EXIT_ATR_STOP_MULT=2.0
EXIT_ATR_CHANDELIER_MULT=3.0
EXIT_RISK_REWARD_RATIO=2.5
EXIT_VAR_PERIOD=252
EXIT_VAR_CONFIDENCE=0.05
EXIT_TRAILING_ACTIVATION_PCT=1.5
SCORE_EMERGENCY_SELL_THRESHOLD=20.0

ENTRY_MIN_QUALITY=50.0
ENTRY_MIN_SCORE_VELOCITY=-999.0
ENTRY_VELOCITY_WINDOW=5
ENTRY_RSI_IDEAL_MAX=65.0
ENTRY_BOLLINGER_B_MAX=0.60
ENTRY_VOL_MIN_RATIO=0.80
ENTRY_BULL_RATIO_MIN=0.25
ENTRY_REGIME_BYPASS_MIN_SCORE=76.0
ENTRY_REGIME_BYPASS_MIN_VELOCITY=1.0
ENTRY_REGIME_BYPASS_MAX_RSI=55.0
ENTRY_PULLBACK_MULT=0.3
ENTRY_LIMIT_TIMEOUT_TICKS=2
ENTRY_W_VELOCITY=0.45
ENTRY_W_PRICE=0.25
ENTRY_W_VOLUME=0.15
ENTRY_W_REGIME=0.15

SCORE_BUY_THRESHOLD=68.0
SCORE_SELL_THRESHOLD=40.0
SCORE_TOP_N=50
SCORE_SECTOR_TOP_N=5

WEIGHT_DEFAULT_TECHNICAL=0.45
WEIGHT_DEFAULT_FUNDAMENTAL=0.25
WEIGHT_DEFAULT_MOMENTUM=0.30
WEIGHT_IT_TECHNICAL=0.50
WEIGHT_IT_FUNDAMENTAL=0.20
WEIGHT_IT_MOMENTUM=0.30
WEIGHT_BANKING_TECHNICAL=0.40
WEIGHT_BANKING_FUNDAMENTAL=0.35
WEIGHT_BANKING_MOMENTUM=0.25
WEIGHT_PSU_BANK_TECHNICAL=0.42
WEIGHT_PSU_BANK_FUNDAMENTAL=0.32
WEIGHT_PSU_BANK_MOMENTUM=0.26
WEIGHT_PHARMA_TECHNICAL=0.45
WEIGHT_PHARMA_FUNDAMENTAL=0.25
WEIGHT_PHARMA_MOMENTUM=0.30
WEIGHT_AUTO_TECHNICAL=0.45
WEIGHT_AUTO_FUNDAMENTAL=0.25
WEIGHT_AUTO_MOMENTUM=0.30
WEIGHT_FMCG_TECHNICAL=0.35
WEIGHT_FMCG_FUNDAMENTAL=0.35
WEIGHT_FMCG_MOMENTUM=0.30
WEIGHT_METAL_TECHNICAL=0.45
WEIGHT_METAL_FUNDAMENTAL=0.15
WEIGHT_METAL_MOMENTUM=0.40
WEIGHT_ENERGY_TECHNICAL=0.45
WEIGHT_ENERGY_FUNDAMENTAL=0.25
WEIGHT_ENERGY_MOMENTUM=0.30
WEIGHT_REALTY_TECHNICAL=0.40
WEIGHT_REALTY_FUNDAMENTAL=0.20
WEIGHT_REALTY_MOMENTUM=0.40
WEIGHT_INFRA_TECHNICAL=0.45
WEIGHT_INFRA_FUNDAMENTAL=0.25
WEIGHT_INFRA_MOMENTUM=0.30
WEIGHT_FINANCIAL_TECHNICAL=0.40
WEIGHT_FINANCIAL_FUNDAMENTAL=0.35
WEIGHT_FINANCIAL_MOMENTUM=0.25
WEIGHT_MEDIA_TECHNICAL=0.48
WEIGHT_MEDIA_FUNDAMENTAL=0.22
WEIGHT_MEDIA_MOMENTUM=0.30
WEIGHT_CONSUMER_TECHNICAL=0.42
WEIGHT_CONSUMER_FUNDAMENTAL=0.28
WEIGHT_CONSUMER_MOMENTUM=0.30

WEIGHT_TECH_RSI=0.12
WEIGHT_TECH_MACD=0.22
WEIGHT_TECH_BOLLINGER=0.13
WEIGHT_TECH_SMA_CROSS=0.18
WEIGHT_TECH_VOLUME=0.15
WEIGHT_TECH_MOMENTUM=0.20

WEIGHT_FUND_PE=0.15
WEIGHT_FUND_PB=0.10
WEIGHT_FUND_ROE=0.15
WEIGHT_FUND_DE=0.12
WEIGHT_FUND_CURR_RATIO=0.08
WEIGHT_FUND_REV_GROWTH=0.12
WEIGHT_FUND_EPS_GROWTH=0.12
WEIGHT_FUND_MARGIN=0.10
WEIGHT_FUND_DIVIDEND=0.06

SENTIMENT_COMPOSITE_WEIGHT=0.10
SENTIMENT_KEYWORD_WEIGHT=0.50
SENTIMENT_MAX_AGE_HOURS=24
SENTIMENT_RECENCY_DECAY=0.08
SENTIMENT_MIN_ARTICLES=2
