GROWW_API_KEY=abc
GROWW_SECRET=abc

# AWS SNS topic ARN for end-of-day trade summary email (leave blank to disable)
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:729756086652:NotifySelft


# =============================================================================
#  LOGGING  —  size-based rotation (total cap = LOG_MAX_BYTES × (LOG_BACKUP_COUNT + 1))
# =============================================================================

# Max size of a single log file before it rotates (bytes).
# Default: 1 GB  =  1073741824
# Examples:
#   500 MB  →  524288000
#   200 MB  →  209715200
LOG_MAX_BYTES=1073741824

# Number of rotated backup files to keep (bot.log.1 … bot.log.N).
# Total disk cap = LOG_MAX_BYTES × (LOG_BACKUP_COUNT + 1)
# Default: 19 backups → 20 files × 1 GB = 20 GB cap
# Reduce if disk is tight (e.g. 4 → 5 × 1 GB = 5 GB cap)
LOG_BACKUP_COUNT=19


# =============================================================================
#  BOT BEHAVIOUR
# =============================================================================

# true  → simulate everything, no real money moves  (safe default)
# false → live trading ⚠️  flip only when you're confident
BOT_DRY_RUN=true

# Fallback interval (used if specific open/closed intervals aren't set)
BOT_POLL_INTERVAL=300

# During market hours (09:15–15:30 IST) — live prices injected, scores change each tick
# 60  = check every minute  (recommended: aggressive but not spammy)
# 120 = every 2 min         (balanced)
# 30  = every 30s           (very aggressive, higher NSE API load)
BOT_POLL_INTERVAL_OPEN=60

# Outside market hours — only news sentiment can change, prices are frozen
# 3600 = once per hour  (recommended)
BOT_POLL_INTERVAL_CLOSED=3600


# =============================================================================
#  RISK CONTROLS  —  hard limits, bot stops if breached
# =============================================================================

# Pause all new orders if today's realized loss exceeds this (INR)
RISK_MAX_DAILY_LOSS=1000.0

# Max number of stocks held simultaneously
RISK_MAX_HOLDINGS=10

# Hard cap on qty per single order (prevents runaway orders)
RISK_MAX_QTY_PER_ORDER=10

# Shares to buy/sell per signal (used only when RISK_DYNAMIC_SIZING=false)
RISK_QUANTITY_PER_TRADE=1

# =============================================================================
#  EXIT CONTROLS  —  Statistically-derived, per-stock exit levels
#
#  Instead of hardcoded percentages, exit levels are computed fresh each tick
#  from the stock's own ATR (Average True Range) and return distribution (VaR).
#
#  A volatile small-cap gets a wider stop automatically (won't get stopped out
#  by normal noise). A stable large-cap gets a tighter stop (less room to lose).
#
#  Three research-backed methods, blended (tightest stop wins):
#
#  1. ATR Stop (Wilder 1978)
#     stop  = entry − ATR_STOP_MULT × ATR(ATR_PERIOD)
#     trail = peak  − ATR_CHANDELIER_MULT × ATR    ← Chandelier Exit (LeBeau 1999)
#     tp    = entry + RISK_REWARD_RATIO × stop_dist (maintain R:R ratio)
#
#  2. Parametric VaR (Normal distribution fit over VAR_PERIOD days)
#     stop  = entry × (1 + z_score × σ + μ)
#     where z_score = norm.ppf(VAR_CONFIDENCE), e.g. -1.645 at 5%
#     Only 5% of historical days lost more than this amount.
#
#  3. Historical VaR (non-parametric — raw sorted percentiles, no assumptions)
#     stop  = entry × (1 + percentile(returns, 5))
#
#  Final stop = max(ATR stop, parametric VaR stop, empirical VaR stop)
#  (most conservative = tightest = smallest loss if triggered)
#
#  Priority order on each tick:
#   1. ATR/VaR stop-loss  → cap the loss
#   2. Take-profit        → lock in gain (R:R multiple of stop distance)
#   3. Chandelier trail   → protect accumulated profit (arms after N% gain)
#   4. Score exit         → ONLY fires when already in profit
#   5. Emergency exit     → score collapsed (< SCORE_EMERGENCY_SELL_THRESHOLD)
# =============================================================================

# ATR period — Wilder's default is 14 trading days
EXIT_ATR_PERIOD=14

# Stop-loss = entry − (MULT × ATR).  Larger = wider stop = less noise triggers.
# Typical range: 1.5 (tight) to 3.0 (wide, for highly volatile stocks)
EXIT_ATR_STOP_MULT=2.0

# Chandelier trailing stop = peak − (MULT × ATR).  LeBeau's default = 3.0
# Wider than stop-loss mult to give winners room to breathe
EXIT_ATR_CHANDELIER_MULT=3.0

# Risk:Reward ratio — take-profit = entry + (R:R × stop_distance)
# 2.0 means: if you risk ₹20, target ₹40 profit (minimum for positive EV)
# 3.0 is more conservative / selective
EXIT_RISK_REWARD_RATIO=2.0

# VaR lookback window in trading days  (252 = 1 full year)
EXIT_VAR_PERIOD=252

# VaR confidence level — 0.05 = 95% confidence (5th percentile worst daily return)
# Lower = tighter stop.  0.10 = 90% confidence (less conservative)
EXIT_VAR_CONFIDENCE=0.05

# Activate Chandelier trailing stop only after position is up this much %
# Prevents the trail from triggering before you've built a meaningful gain
EXIT_TRAILING_ACTIVATION_PCT=2.0

# Score emergency exit threshold — sell even at a loss if score collapses below this
# Normal score exit (above) only fires in profit. This fires when fundamentals break down.
SCORE_EMERGENCY_SELL_THRESHOLD=20.0


# =============================================================================
#  ENTRY QUALITY CONTROLS  —  Enter early, at the best price, in the right market
#
#  Instead of "score >= 70 → buy immediately", every BUY candidate is evaluated
#  on five dimensions before a signal is generated:
#
#  1. SCORE VELOCITY     — is the score rising (early in move) or falling (peak)?
#  2. PRICE ENTRY        — is the current price near support (max upside)?
#                          Uses RSI, Bollinger %B, and distance from ATR support.
#  3. VOLUME             — is volume confirming institutional participation?
#  4. MARKET REGIME      — are most NSE stocks in a healthy state?
#  5. ENTRY PRICE        — limit order at slight pullback for better fill
#
#  If all pass → BUY signal generated (LIMIT or MARKET depending on quality)
#  If any fail → skip this tick, re-evaluate next tick
# =============================================================================

# Minimum composite entry quality (0–100). Below this → skip this tick.
# 55 = balanced (some selectivity).  70 = strict (fewer but better entries).
ENTRY_MIN_QUALITY=55.0

# Minimum score velocity (score pts/tick). 0 = reject only if falling.
# 0.5 = require score to be rising at ≥ 0.5pts/tick (more selective).
ENTRY_MIN_SCORE_VELOCITY=-0.5

# Ticks of score history used for velocity regression (linear fit).
ENTRY_VELOCITY_WINDOW=5

# RSI at or below this = "not overbought at entry" = full price score.
# Lower = stricter (only buy deeply oversold stocks with high scores).
ENTRY_RSI_IDEAL_MAX=55.0

# Bollinger %B at or below this = buying near lower band = good entry.
ENTRY_BOLLINGER_B_MAX=0.55

# Reject if today's volume < this fraction of the 20-day average.
# 0.8 = require at least 80% of average volume (avoid ghost moves).
ENTRY_VOL_MIN_RATIO=0.8

# Reject if fewer than this fraction of NSE stocks score > 50 (bear market filter).
ENTRY_BULL_RATIO_MIN=0.40

# ── Bullish Divergence Bypass ────────────────────────────────────────────────
# When the market is in a bear regime (bull_ratio < ENTRY_BULL_RATIO_MIN),
# the bot normally blocks ALL buys.  The bypass allows an exceptional stock to
# be purchased if it shows relative strength divergence — ALL THREE conditions
# must hold simultaneously:
#
#   composite score  >= ENTRY_REGIME_BYPASS_MIN_SCORE    (structurally excellent)
#   score velocity   >= ENTRY_REGIME_BYPASS_MIN_VELOCITY (actively improving)
#   RSI              <= ENTRY_REGIME_BYPASS_MAX_RSI       (price already beaten down)
#
# Bypass buys always use LIMIT orders at 1.5× the normal pullback.
# Set ENTRY_REGIME_BYPASS_MIN_SCORE=200 to disable the bypass entirely.

ENTRY_REGIME_BYPASS_MIN_SCORE=78.0
ENTRY_REGIME_BYPASS_MIN_VELOCITY=1.5
ENTRY_REGIME_BYPASS_MAX_RSI=45.0

# Limit order pullback multiplier: limit = ltp − MULT × ATR.
# 0.5 = try to buy at half an ATR below current price (small pullback target).
# 0.0 = always use market orders (no limit orders).
ENTRY_PULLBACK_MULT=0.5

# Cancel limit and switch to market after this many ticks with no fill.
# 3 ticks = ~3 minutes (at 60s poll interval). Prevents missing genuine breakouts.
ENTRY_LIMIT_TIMEOUT_TICKS=3

# Entry quality sub-weights (must sum to 1.0)
ENTRY_W_VELOCITY=0.30   # score improving? (most important — maximises entry-exit window)
ENTRY_W_PRICE=0.35      # price at good entry point? (RSI, %B, distance from support)
ENTRY_W_VOLUME=0.15     # volume confirming institutional interest?
ENTRY_W_REGIME=0.20     # broad market healthy?

# Dynamic position sizing — computes qty from wallet balance automatically
# true  → qty = floor((balance × deploy_fraction) / open_slots / ltp)
# false → always use RISK_QUANTITY_PER_TRADE (static)
RISK_DYNAMIC_SIZING=true

# Fraction of available CNC balance to deploy (0.90 = 90%, keeps 10% as buffer)
RISK_DEPLOY_FRACTION=0.90

# Simulated wallet balance used in dry-run mode for position sizing (INR)
RISK_DRY_RUN_BALANCE=100000.0


# =============================================================================
#  SIGNAL THRESHOLDS  —  composite score is always 0–100
# =============================================================================

# Stock must score AT OR ABOVE this → BUY
# Higher = fewer, higher-conviction trades  |  Lower = more trades, more noise
SCORE_BUY_THRESHOLD=70.0

# Held stock scoring BELOW this → SELL
# Higher = exit faster on weakness  |  Lower = hold through dips
SCORE_SELL_THRESHOLD=40.0

# Only consider the top-N stocks as BUY candidates each tick
# Keeps the bot focused instead of scanning all 2,117 stocks
SCORE_TOP_N=50
SCORE_SECTOR_TOP_N=5        # top K stocks shown per sector in logs / score table


# =============================================================================
#  COMPOSITE SCORE PILLAR WEIGHTS  (must sum to 1.0 per sector)
#
#  Three pillars:
#    TECHNICAL   — price-action signals: RSI, MACD, Bollinger, SMA, Volume, Momentum
#    FUNDAMENTAL — business quality:     P/E, P/B, ROE, D/E, Growth, Margin
#    MOMENTUM    — multi-period return:  1M / 3M / 6M price change
#
#  Different sectors need different balances:
#    Banking  → fundamentals dominate (P/B, ROE are everything)
#    IT       → technicals + growth matter most
#    Metal    → pure momentum (tracks global commodity prices)
# =============================================================================

# ── DEFAULT  (used when a sector has no explicit override below) ─────────────
WEIGHT_DEFAULT_TECHNICAL=0.40
WEIGHT_DEFAULT_FUNDAMENTAL=0.35
WEIGHT_DEFAULT_MOMENTUM=0.25

# ── IT / TECHNOLOGY ──────────────────────────────────────────────────────────
# Growth sector. P/E is naturally high — revenue growth is the real thesis.
WEIGHT_IT_TECHNICAL=0.45
WEIGHT_IT_FUNDAMENTAL=0.30
WEIGHT_IT_MOMENTUM=0.25

# ── BANKING (private banks) ───────────────────────────────────────────────────
# P/B + ROE are the primary valuation metrics. D/E is irrelevant (banks are
# structurally leveraged via customer deposits — that's their business model).
WEIGHT_BANKING_TECHNICAL=0.35
WEIGHT_BANKING_FUNDAMENTAL=0.45
WEIGHT_BANKING_MOMENTUM=0.20

# ── PSU BANKS ─────────────────────────────────────────────────────────────────
# Same as banking but with extra policy risk → slightly more technical weight
# to catch government-scheme-driven rallies.
WEIGHT_PSU_BANK_TECHNICAL=0.38
WEIGHT_PSU_BANK_FUNDAMENTAL=0.42
WEIGHT_PSU_BANK_MOMENTUM=0.20

# ── PHARMA / HEALTHCARE ───────────────────────────────────────────────────────
# R&D-driven. High technical weight catches USFDA approval/rejection moves.
WEIGHT_PHARMA_TECHNICAL=0.40
WEIGHT_PHARMA_FUNDAMENTAL=0.35
WEIGHT_PHARMA_MOMENTUM=0.25

# ── AUTO / AUTOMOBILES ────────────────────────────────────────────────────────
# Cyclical. Momentum captures EV transitions and monthly sales surprises.
WEIGHT_AUTO_TECHNICAL=0.42
WEIGHT_AUTO_FUNDAMENTAL=0.33
WEIGHT_AUTO_MOMENTUM=0.25

# ── FMCG  ────────────────────────────────────────────────────────────────────
# Defensive compounders. Fundamentals dominate — brands and margins are durable.
WEIGHT_FMCG_TECHNICAL=0.30
WEIGHT_FMCG_FUNDAMENTAL=0.50
WEIGHT_FMCG_MOMENTUM=0.20

# ── METAL / MINING ────────────────────────────────────────────────────────────
# Commodity-linked. Price follows global metal cycles — pure momentum sector.
WEIGHT_METAL_TECHNICAL=0.50
WEIGHT_METAL_FUNDAMENTAL=0.20
WEIGHT_METAL_MOMENTUM=0.30

# ── ENERGY (oil, gas, power) ──────────────────────────────────────────────────
WEIGHT_ENERGY_TECHNICAL=0.42
WEIGHT_ENERGY_FUNDAMENTAL=0.35
WEIGHT_ENERGY_MOMENTUM=0.23

# ── REALTY ────────────────────────────────────────────────────────────────────
# Highly cyclical. Momentum is a strong signal in this sector.
WEIGHT_REALTY_TECHNICAL=0.45
WEIGHT_REALTY_FUNDAMENTAL=0.25
WEIGHT_REALTY_MOMENTUM=0.30

# ── INFRASTRUCTURE ────────────────────────────────────────────────────────────
# Government capex driven. Momentum catches budget / order-win rallies.
WEIGHT_INFRA_TECHNICAL=0.43
WEIGHT_INFRA_FUNDAMENTAL=0.32
WEIGHT_INFRA_MOMENTUM=0.25

# ── FINANCIAL SERVICES (NBFCs, insurance, AMCs) ───────────────────────────────
WEIGHT_FINANCIAL_TECHNICAL=0.35
WEIGHT_FINANCIAL_FUNDAMENTAL=0.45
WEIGHT_FINANCIAL_MOMENTUM=0.20

# ── MEDIA / ENTERTAINMENT ─────────────────────────────────────────────────────
WEIGHT_MEDIA_TECHNICAL=0.45
WEIGHT_MEDIA_FUNDAMENTAL=0.30
WEIGHT_MEDIA_MOMENTUM=0.25

# ── CONSUMER DURABLES ─────────────────────────────────────────────────────────
WEIGHT_CONSUMER_TECHNICAL=0.40
WEIGHT_CONSUMER_FUNDAMENTAL=0.38
WEIGHT_CONSUMER_MOMENTUM=0.22


# =============================================================================
#  TECHNICAL INDICATOR SUB-WEIGHTS  (must sum to 1.0)
#
#  RSI        — Relative Strength Index (14d)       overbought / oversold
#  MACD       — Moving Avg Convergence Divergence   trend shift + acceleration
#  BOLLINGER  — Bollinger Bands %B                  near lower band = bullish
#  SMA_CROSS  — SMA50 vs SMA200 alignment           golden / death cross
#  VOLUME     — Volume vs 20d average               confirms moves with conviction
#  MOMENTUM   — 1M / 3M / 6M price return combined  trend persistence
# =============================================================================

WEIGHT_TECH_RSI=0.15
WEIGHT_TECH_MACD=0.20
WEIGHT_TECH_BOLLINGER=0.15
WEIGHT_TECH_SMA_CROSS=0.20
WEIGHT_TECH_VOLUME=0.15
WEIGHT_TECH_MOMENTUM=0.15


# =============================================================================
#  FUNDAMENTAL INDICATOR SUB-WEIGHTS  (must sum to 1.0 per sector)
#
#  PE          — Price / Earnings           valuation (lower = cheaper)
#  PB          — Price / Book              asset value (key for banks)
#  ROE         — Return on Equity          capital efficiency (Buffett's #1)
#  DE          — Debt / Equity             leverage (lower = safer)
#  CURR_RATIO  — Current Assets / Liab     short-term solvency
#  REV_GROWTH  — Revenue YoY growth        top-line momentum
#  EPS_GROWTH  — EPS YoY growth            bottom-line momentum
#  MARGIN      — Net profit margin         pricing power + cost discipline
#  DIVIDEND    — Dividend yield            income signal + mgmt confidence
# =============================================================================

# ── Default fundamental sub-weights ─────────────────────────────────────────
WEIGHT_FUND_PE=0.15
WEIGHT_FUND_PB=0.10
WEIGHT_FUND_ROE=0.15
WEIGHT_FUND_DE=0.12
WEIGHT_FUND_CURR_RATIO=0.08
WEIGHT_FUND_REV_GROWTH=0.12
WEIGHT_FUND_EPS_GROWTH=0.12
WEIGHT_FUND_MARGIN=0.10
WEIGHT_FUND_DIVIDEND=0.06

# ── Banking overrides  (D/E and Current Ratio are zeroed — irrelevant for banks)
WEIGHT_FUND_BANKING_PE=0.08
WEIGHT_FUND_BANKING_PB=0.20
WEIGHT_FUND_BANKING_ROE=0.22
WEIGHT_FUND_BANKING_DE=0.00
WEIGHT_FUND_BANKING_CURR_RATIO=0.00
WEIGHT_FUND_BANKING_REV_GROWTH=0.15
WEIGHT_FUND_BANKING_EPS_GROWTH=0.15
WEIGHT_FUND_BANKING_MARGIN=0.12
WEIGHT_FUND_BANKING_DIVIDEND=0.08

# ── IT overrides  (growth and margin are the core thesis, P/E less penalised)
WEIGHT_FUND_IT_PE=0.10
WEIGHT_FUND_IT_PB=0.06
WEIGHT_FUND_IT_ROE=0.15
WEIGHT_FUND_IT_DE=0.08
WEIGHT_FUND_IT_CURR_RATIO=0.05
WEIGHT_FUND_IT_REV_GROWTH=0.20
WEIGHT_FUND_IT_EPS_GROWTH=0.18
WEIGHT_FUND_IT_MARGIN=0.15
WEIGHT_FUND_IT_DIVIDEND=0.03

# ── Pharma overrides  (pipeline + margins drive returns, not current P/E)
WEIGHT_FUND_PHARMA_PE=0.12
WEIGHT_FUND_PHARMA_PB=0.06
WEIGHT_FUND_PHARMA_ROE=0.18
WEIGHT_FUND_PHARMA_DE=0.10
WEIGHT_FUND_PHARMA_CURR_RATIO=0.03
WEIGHT_FUND_PHARMA_REV_GROWTH=0.14
WEIGHT_FUND_PHARMA_EPS_GROWTH=0.20
WEIGHT_FUND_PHARMA_MARGIN=0.16
WEIGHT_FUND_PHARMA_DIVIDEND=0.01


# =============================================================================
#  NEWS SENTIMENT WEIGHTS
#
#  Sentiment is the 4th pillar blended into the composite score.
#  It combines an NLP model score with a keyword event booster.
#
#  Positive keyword examples: "product launch", "order win", "record revenue"
#  Negative keyword examples: "SEBI notice", "earnings miss", "promoter pledge"
# =============================================================================

# Share of composite score coming from news sentiment (0.0 = disabled)
# 0.15 = balanced  |  0.25 = news-reactive  |  0.00 = technical-only mode
SENTIMENT_COMPOSITE_WEIGHT=0.15

# NLP model vs keyword event detection balance (0.0 = pure NLP, 1.0 = pure keywords)
# 0.4 = balanced default — let keywords override model on high-conviction events
SENTIMENT_KEYWORD_WEIGHT=0.40

# Discard articles older than this many hours
SENTIMENT_MAX_AGE_HOURS=48

# Exponential weight decay per hour of article age
# 0.05 = article 14h old has ~50% weight of a brand-new article
SENTIMENT_RECENCY_DECAY=0.05

# Require at least this many articles; else return neutral score (50)
SENTIMENT_MIN_ARTICLES=2

# How long to cache RSS results before re-fetching (minutes)
SENTIMENT_CACHE_MINUTES=30


# =============================================================================
#  INTRADAY PULSE  —  live price sensitivity (market hours only: 09:15–15:30)
#
#  A 5th scoring pillar that uses only same-day live candle data.
#  Active ONLY when the market is open — has zero effect outside hours.
#
#  Four components (each 0–100, 50 = perfectly neutral):
#    DAY_RETURN      — today's % return vs yesterday's close  (±3% → 0–100)
#    RANGE_POSITION  — where LTP sits between today's High and Low
#    VOLUME_PACE     — today's volume vs expected (avg × session fraction)
#    OPEN_DISTANCE   — distance of LTP from today's open price (±2% → 0–100)
#
#  Blending (delta-based — same formula as news sentiment):
#    delta = (pulse − 50) / 50             # −1.0 to +1.0
#    boost = delta × PULSE_WEIGHT × base   # proportional nudge
#    new   = base + boost
#
#  Key property: pulse=50 (flat day, mid-range, on-pace) → boost=0 → unchanged.
# =============================================================================

# How strongly intraday momentum can move the composite score.
# 0.20 = up to ±20% nudge on base  (e.g. ±13.6 pts on a score of 68)
# 0.10 = subtle nudge              (conservative)
# 0.00 = disable intraday pulse entirely
INTRADAY_PULSE_WEIGHT=0.20

# Sub-component weights — must sum to 1.0
# day_return and range_position capture "is the stock rallying today?"
# volume_pace adds conviction ("volume confirms the move")
# open_distance shows intraday drift from the opening price
INTRADAY_W_DAY_RETURN=0.35
INTRADAY_W_RANGE_POSITION=0.30
INTRADAY_W_VOLUME_PACE=0.25
INTRADAY_W_OPEN_DISTANCE=0.10